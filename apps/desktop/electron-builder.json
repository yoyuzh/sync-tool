{
  "appId": "com.yoyuzh.sync-tool",
  "productName": "sync-tool",
  "directories": {
    "output": "release"
  },
  "icon": "assets/icons/icon.png",
  "files": [
    "dist/**",
    "dist-electron/**",
    "assets/**",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist-electron/main.cjs"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "yoyuzh",
      "repo": "sync-tool"
    }
  ],
  "mac": {
    "icon": "assets/icons/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "arm64"
        ]
      }
    ],
    "category": "public.app-category.productivity"
  },
  "win": {
    "icon": "assets/icons/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
