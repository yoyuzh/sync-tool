{
  "appId": "com.yoyuzh.sync-tool",
  "productName": "sync-tool",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**",
    "dist-electron/**",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist-electron/main.cjs"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "arm64"
        ]
      }
    ],
    "category": "public.app-category.productivity"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
